<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.UrduKeyboard" parent="Theme.Material3.DayNight">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor" tools:targetApi="l">?attr/colorPrimaryVariant</item>
        <!-- Customize your theme here. -->
    </style>
    
    <!-- Keyboard Theme -->
    <style name="KeyboardTheme">
        <item name="android:background">@color/keyboard_background_default</item>
    </style>
    
    <!-- Key Button Style -->
    <style name="KeyButton">
        <item name="android:layout_margin">2dp</item>
        <item name="android:background">@drawable/key_background</item>
        <item name="android:textColor">@color/key_text_color</item>
        <item name="android:textSize">16sp</item>
        <item name="android:gravity">center</item>
        <item name="android:fontFamily">@font/open_sans</item>
        <item name="android:elevation">2dp</item>
    </style>
    
    <!-- Urdu Key Button Style -->
    <style name="UrduKeyButton" parent="KeyButton">
        <item name="android:background">@drawable/urdu_key_background</item>
        <item name="android:textColor">@color/urdu_text_color</item>
        <item name="android:textSize">18sp</item>
        <item name="android:fontFamily">@font/nastaleq</item>
    </style>
    
    <!-- Special Key Button Style -->
    <style name="SpecialKeyButton" parent="KeyButton">
        <item name="android:background">@drawable/special_key_background</item>
        <item name="android:textSize">14sp</item>
    </style>
    
    <!-- Color Button Style -->
    <style name="ColorButton">
        <item name="android:layout_width">40dp</item>
        <item name="android:layout_height">40dp</item>
        <item name="android:layout_margin">4dp</item>
        <item name="android:layout_gravity">fill</item>
    </style>
</resources>