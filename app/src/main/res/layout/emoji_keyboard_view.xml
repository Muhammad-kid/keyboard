<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/keyboard_background_default"
    android:padding="4dp">

    <!-- First Row: Smileys -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="2dp">

        <Button android:id="@+id/emoji_1" style="@style/KeyButton" android:layout_weight="1" android:text="😀" android:textSize="20sp" />
        <Button android:id="@+id/emoji_2" style="@style/KeyButton" android:layout_weight="1" android:text="😂" android:textSize="20sp" />
        <Button android:id="@+id/emoji_3" style="@style/KeyButton" android:layout_weight="1" android:text="😍" android:textSize="20sp" />
        <Button android:id="@+id/emoji_4" style="@style/KeyButton" android:layout_weight="1" android:text="😘" android:textSize="20sp" />
        <Button android:id="@+id/emoji_5" style="@style/KeyButton" android:layout_weight="1" android:text="😊" android:textSize="20sp" />
        <Button android:id="@+id/emoji_6" style="@style/KeyButton" android:layout_weight="1" android:text="😎" android:textSize="20sp" />
        <Button android:id="@+id/emoji_7" style="@style/KeyButton" android:layout_weight="1" android:text="😢" android:textSize="20sp" />
        <Button android:id="@+id/emoji_8" style="@style/KeyButton" android:layout_weight="1" android:text="😭" android:textSize="20sp" />
    </LinearLayout>

    <!-- Second Row: Hearts and Hands -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="2dp">

        <Button android:id="@+id/emoji_9" style="@style/KeyButton" android:layout_weight="1" android:text="❤️" android:textSize="20sp" />
        <Button android:id="@+id/emoji_10" style="@style/KeyButton" android:layout_weight="1" android:text="💕" android:textSize="20sp" />
        <Button android:id="@+id/emoji_11" style="@style/KeyButton" android:layout_weight="1" android:text="👍" android:textSize="20sp" />
        <Button android:id="@+id/emoji_12" style="@style/KeyButton" android:layout_weight="1" android:text="👎" android:textSize="20sp" />
        <Button android:id="@+id/emoji_13" style="@style/KeyButton" android:layout_weight="1" android:text="🙏" android:textSize="20sp" />
        <Button android:id="@+id/emoji_14" style="@style/KeyButton" android:layout_weight="1" android:text="👏" android:textSize="20sp" />
        <Button android:id="@+id/emoji_15" style="@style/KeyButton" android:layout_weight="1" android:text="🤝" android:textSize="20sp" />
        <Button android:id="@+id/emoji_16" style="@style/KeyButton" android:layout_weight="1" android:text="✌️" android:textSize="20sp" />
    </LinearLayout>

    <!-- Third Row: Animals and Nature -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="2dp">

        <Button android:id="@+id/emoji_17" style="@style/KeyButton" android:layout_weight="1" android:text="🐱" android:textSize="20sp" />
        <Button android:id="@+id/emoji_18" style="@style/KeyButton" android:layout_weight="1" android:text="🐶" android:textSize="20sp" />
        <Button android:id="@+id/emoji_19" style="@style/KeyButton" android:layout_weight="1" android:text="🌹" android:textSize="20sp" />
        <Button android:id="@+id/emoji_20" style="@style/KeyButton" android:layout_weight="1" android:text="🌟" android:textSize="20sp" />
        <Button android:id="@+id/emoji_21" style="@style/KeyButton" android:layout_weight="1" android:text="☀️" android:textSize="20sp" />
        <Button android:id="@+id/emoji_22" style="@style/KeyButton" android:layout_weight="1" android:text="🌙" android:textSize="20sp" />
        <Button android:id="@+id/emoji_23" style="@style/KeyButton" android:layout_weight="1" android:text="⭐" android:textSize="20sp" />
        <Button android:id="@+id/emoji_24" style="@style/KeyButton" android:layout_weight="1" android:text="🎉" android:textSize="20sp" />
    </LinearLayout>

    <!-- Fourth Row: Control Keys -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button android:id="@+id/key_abc_emoji" style="@style/SpecialKeyButton" android:layout_weight="2" android:text="@string/key_abc" />
        <Button android:id="@+id/key_space_emoji" style="@style/SpecialKeyButton" android:layout_weight="4" android:text="@string/key_space" />
        <Button android:id="@+id/key_backspace_emoji" style="@style/SpecialKeyButton" android:layout_weight="2" android:text="⌫" />
    </LinearLayout>

</LinearLayout>